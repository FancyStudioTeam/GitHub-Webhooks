{
	"author": "FancyStudio",
	"dependencies": {
		"@actions/core": "3.0.0",
		"@actions/github": "9.0.0",
		"@discordjs/builders": "1.13.1",
		"discord-api-types": "0.38.42",
		"ts-pattern": "5.9.0"
	},
	"description": "A collection of custom GitHub Actions used in FancyStudio",
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@octokit/webhooks-types": "7.6.1",
		"@rollup/plugin-commonjs": "29.0.2",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@rollup/plugin-typescript": "12.3.0",
		"@types/node": "25.5.0",
		"rimraf": "6.1.3",
		"rollup": "4.59.0",
		"typescript": "6.0.2"
	},
	"license": "MIT",
	"main": "src/index.ts",
	"name": "github-actions",
	"packageManager": "pnpm@10.0.0",

{
	"author": "FancyStudio",
	"dependencies": {
		"@discordjs/builders": "1.14.1",
		"@octokit/webhooks": "14.2.0",
		"discord-api-types": "0.38.46",
		"ts-pattern": "5.9.0"
	},
	"description": "An application that manages incoming GitHub Webhooks within the FancyStudio organization",
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@commitlint/types": "20.5.0",
		"@octokit/webhooks-types": "7.6.1",
		"@types/node": "25.6.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"typescript": "6.0.2",
		"wrangler": "4.82.2"
	},
	"license": "MIT",
	"main": "src/index.ts",
	"name": "github-webhooks",
	"packageManager": "pnpm@10.0.0",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/FancyStudioTeam/GitHub-Webhooks"
